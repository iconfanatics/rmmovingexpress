# =============================================================================
# Client (Next.js) Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values
# =============================================================================

NODE_ENV=development

# Backend API endpoints (use 'backend' for Docker, 'localhost' for local)
NEXT_PUBLIC_API_ENDPOINT=http://backend:3334/api
NEXT_PUBLIC_API_BASE_URL=http://backend:3334/api/v1
NEXT_PUBLIC_API_IMAGES_URL=http://backend:3334
API_BASE_URL=http://backend:3334/api
