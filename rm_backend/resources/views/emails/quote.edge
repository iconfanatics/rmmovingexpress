<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title>Contact Us Email</title>
</head>
<body style="margin:0; padding:0; font-family: Arial, sans-serif; background-color:#f7f7f7;">
  <table width="100%" border="0" cellspacing="0" cellpadding="0" bgcolor="#f7f7f7">
    <tr>
      <td align="center" style="padding: 30px 10px;">
        <!-- Email Container -->
        <table width="600" border="0" cellspacing="0" cellpadding="0" bgcolor="#ffffff" style="border-radius:8px; overflow:hidden; box-shadow:0 4px 8px rgba(0,0,0,0.1);">
          <!-- Header -->
          <tr>
            <td bgcolor="#2c3e50" align="center" style="padding:20px;">
              <h2 style="color:#ffffff; margin:0;">New Quote Submission</h2>
            </td>
          </tr>

          <!-- Body -->
          <tr>
            <td style="padding: 20px; color:#333;">
              <p style="font-size:16px; margin:0 0 15px;">
                Welcome to <strong>RM Moving Express</strong>, you have a new quote request:
              </p>

              <table width="100%" border="0" cellspacing="0" cellpadding="8" style="font-size:15px; color:#333;">
                <tr>
                  <td width="30%"><strong>Client Name:</strong></td>
                  <td><b>{{name}}</b></td>
                </tr>
                <tr>
                  <td><strong>Client Involved:</strong></td>
                  <td><b>{{involved}}</b></td>
                </tr>
                <tr>
                  <td><strong>Client Number Of Helper:</strong></td>
                  <td><b>{{numberOfHelper}}</b></td>
                </tr>
                <tr>
                  <td><strong>Client Size Of Move:</strong></td>
                  <td><b>{{sizeOfMove}}</b></td>
                </tr>
                <tr>
                  <td valign="top"><strong>Interested:</strong></td>
                  <td><b>{{interested}}</b></td>
                </tr>
                <tr>
                  <td valign="top"><strong>Type Of Move:</strong></td>
                  <td><b>{{typeOfMove}}</b></td>
                </tr>
                <tr>
                  <td valign="top"><strong>Email:</strong></td>
                  <td><b>{{email}}</b></td>
                </tr>
                <tr>
                  <td valign="top"><strong>Phone:</strong></td>
                  <td><b>{{phone}}</b></td>
                </tr>
                <tr>
                  <td valign="top"><strong>Delivery Address:</strong></td>
                  <td><b>{{deliveryAddress}}</b></td>
                </tr>
                <tr>
                  <td valign="top"><strong>Collection Address:</strong></td>
                  <td><b>{{collectionAddress}}</b></td>
                </tr>
                <tr>
                  <td valign="top"><strong>Message:</strong></td>
                  <td><b>{{message}}</b></td>
                </tr>
                
              </table>
            </td>
          </tr>

         
        </table>
        <!-- End Container -->
      </td>
    </tr>
  </table>
</body>
</html>
