# =============================================================================
# Backend (AdonisJS) Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values
# =============================================================================

HOST=0.0.0.0
PORT=3334
NODE_ENV=development

APP_URL=http://localhost:3334
APP_URL_FRONTEND=http://localhost:3000
APP_FRONTEND_URL=http://localhost:3000

CACHE_VIEWS=false

# Generate with: node ace generate:key
APP_KEY=your_app_key_here

# Database (MySQL)
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_USER=rmuser
DB_PASSWORD=rmpassword
DB_DATABASE=rmmovingexpress

SESSION_DRIVER=cookie
HASH_DRIVER=bcrypt

# Image URLs
IMG_URL = '../public/ad/'
IMG_ROBOTICS_URL = '../public/robotics/'
IMG_RESOURCE_CAT_URL = '../public/resourcecat/'
FLAG_URL = '../public/flag/'
HOME_URL = '../public/home/'

# Google OAuth (Optional)
# GOOGLE_CLIENT_ID=your_google_client_id
# GOOGLE_CLIENT_SECRET=your_google_client_secret
# GOOGLE_REDIRECT_URL=http://localhost:3000

# Email - SMTP
# MAIL_CONNECTION=smtp
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# MAIL_USERNAME=your_email@gmail.com
# MAIL_PASSWORD=your_app_password

# Email - AWS SES
# MAIL_CONNECTION=ses
# SES_KEY=your_ses_access_key
# SES_SECRET=your_ses_secret_key
# SES_REGION=us-east-1
