# =============================================================================
# Moving Express - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values
# For local development, copy to rm_backend/.env, rm_client/.env, rm_admin/.env.local
# =============================================================================

# -----------------------------------------------------------------------------
# Database Configuration (MySQL)
# -----------------------------------------------------------------------------
DB_HOST=mysql
DB_PORT=3306
DB_USER=rmuser
DB_PASSWORD=rmpassword
DB_DATABASE=rmmovingexpress
DB_ROOT_PASSWORD=rootpassword

# -----------------------------------------------------------------------------
# Application URLs
# -----------------------------------------------------------------------------
# Backend API
APP_URL=http://localhost:3334
APP_URL_FRONTEND=http://localhost:3000

# Frontend URLs
APP_FRONTEND_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# Server Configuration
# -----------------------------------------------------------------------------
HOST=0.0.0.0
PORT=3334
NODE_ENV=development

# -----------------------------------------------------------------------------
# Security
# -----------------------------------------------------------------------------
# Generate with: node ace generate:key
APP_KEY=your_app_key_here

# -----------------------------------------------------------------------------
# Cache & Sessions
# -----------------------------------------------------------------------------
CACHE_VIEWS=false
SESSION_DRIVER=cookie
HASH_DRIVER=bcrypt

# -----------------------------------------------------------------------------
# Image URLs
# -----------------------------------------------------------------------------
IMG_URL=../public/ad/
IMG_ROBOTICS_URL=../public/robotics/
IMG_RESOURCE_CAT_URL=../public/resourcecat/
FLAG_URL=../public/flag/
HOME_URL=../public/home/

# -----------------------------------------------------------------------------
# Google OAuth (Optional)
# -----------------------------------------------------------------------------
# GOOGLE_CLIENT_ID=your_google_client_id
# GOOGLE_CLIENT_SECRET=your_google_client_secret
# GOOGLE_REDIRECT_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# Email Configuration
# -----------------------------------------------------------------------------
# SMTP (Gmail example)
MAIL_CONNECTION=smtp
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_app_password

# Or AWS SES
# MAIL_CONNECTION=ses
# SES_KEY=your_ses_access_key
# SES_SECRET=your_ses_secret_key
# SES_REGION=us-east-1

# -----------------------------------------------------------------------------
# Frontend API Configuration (rm_client/.env)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_API_ENDPOINT=http://backend:3334/api
NEXT_PUBLIC_API_BASE_URL=http://backend:3334/api/v1
NEXT_PUBLIC_API_IMAGES_URL=http://backend:3334

# -----------------------------------------------------------------------------
# Admin Panel Configuration (rm_admin/.env.local)
# -----------------------------------------------------------------------------
API_URL=http://backend:3334/api/v1
BACKEND_URL=http://backend:3334
WEBSOCKET_CONNECTION_ENDPOINT=backend:3334
WEBSOCKET_BACKEND_CONNECTION_ENDPOINT=backend:3334
